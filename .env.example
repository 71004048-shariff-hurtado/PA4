# ==========================================
# CONFIGURACIÓN DEL BACKEND (api-node-express)
# ==========================================
# Puerto donde correrá el servidor Express
PORT=5000

# URI de conexión a la base de datos de MongoDB
MONGO_URI=mongodb://localhost:27017/bd_portal_estudiante

# Clave secreta para firmar los tokens JWT de autenticación
JWT_SECRET=clave_secreta_jwt_edutech_academy_2026


# ==========================================
# CONFIGURACIÓN DE LA SPA REACT (portal-react)
# ==========================================
# URL de la API REST que consumirá el cliente (Vite requiere prefijo VITE_)
VITE_API_URL=http://localhost:5000/api


# ==========================================
# CONFIGURACIÓN DE LA LANDING NEXT.JS (landing-next)
# ==========================================
# URL de la API REST para renderizado del servidor (SSR)
API_URL=http://localhost:5000/api

# URL de la API REST para llamadas del lado del cliente
NEXT_PUBLIC_API_URL=http://localhost:5000/api
